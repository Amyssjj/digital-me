{
  "name": "digital-me-os",
  "version": "0.1.0-pre",
  "private": true,
  "description": "Digital Me OS — openclaw-based personal brain stack (operations, knowledge, runtime adapters).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "eslint .",
    "knip": "knip",
    "dm": "node packages/cli/dist/bin/digital-me.js",
    "build:cli-bundle": "node scripts/build-cli-bundle.mjs",
    "typecheck": "pnpm -r typecheck",
    "sanitize:check": "bash scripts/sanitize-check.sh",
    "regression": "bash scripts/regression-suite.sh",
    "ci": "pnpm sanitize:check && pnpm build && pnpm typecheck && pnpm lint && pnpm knip && pnpm test:coverage",
    "dashboard": "pnpm --filter @digital-me/dashboard dev",
    "prepare": "[ -d .git ] && command -v husky >/dev/null && husky install || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "knip": "^5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.65.0"
  }
}
