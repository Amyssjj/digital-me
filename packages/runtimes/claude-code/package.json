{
  "name": "@digital-me/runtime-claude-code",
  "version": "0.1.0-pre",
  "description": "Claude Code runtime adapter for the digital-me brain: hooks wired into 3 Claude Code events (UserPromptSubmit / Stop / PreToolUse), the `digital-me` skill, and a settings.json template.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks/*": "./hooks/*",
    "./skills/*": "./skills/*",
    "./templates/*": "./templates/*"
  },
  "files": [
    "dist",
    "src",
    "hooks",
    "skills",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@digital-me/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=22.5"
  }
}
